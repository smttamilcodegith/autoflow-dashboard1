# Copy this file to .env and fill in your Google Sheet CSV URL
#
# How to get your URL:
#   1. Open your Google Sheet
#   2. File → Share → Publish to web
#   3. Under "Link", choose the sheet tab and set format to "Comma-separated values (.csv)"
#   4. Click Publish → copy the URL
#   5. Paste it below
#
VITE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vS8nom4Uh08PUiwxvr1tAa8d83Ez8vMewzXnnHbttx-AnL3RXvp2SwHUOX6J67nx5kh3JGrNu-Xs8T4/pub?output=csv
